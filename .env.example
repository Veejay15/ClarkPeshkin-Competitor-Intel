# Anthropic API key for Claude (used by report generator)
ANTHROPIC_API_KEY=sk-ant-...

# SE Ranking Data API key (used to pull weekly backlinks + keyword data for each competitor)
# Generate at: https://online.seranking.com/account.api.html
SERANKING_API_KEY=
# Optional: ISO country code for organic keyword data (default: us)
SERANKING_SOURCE=us
# Optional: how many days back to scan for new backlinks (default: 30)
# Note: SE Ranking's backlink discovery is bursty for small-to-medium firms.
# A 7-day window often returns 0 results even when the firm is actively earning links.
# 30 days gives the report something concrete to analyze most weeks.
SERANKING_BACKLINK_DAYS=30

# GitHub personal access token (used by Vercel UI to commit changes back to the repo)
# Needs: repo scope
GITHUB_TOKEN=ghp_...

# GitHub repo owner and name (e.g., "yourusername" and "clark-peshkin-competitor-intel")
GITHUB_OWNER=
GITHUB_REPO=clark-peshkin-competitor-intel

# Default branch name (usually "main")
GITHUB_BRANCH=main

# Simple shared password to protect admin actions (add/remove competitors, upload, trigger)
# Set this in Vercel env vars to lock the dashboard
ADMIN_PASSWORD=change-me

# Vercel Blob token (used for large CSV uploads from the dashboard)
# Auto-set when you enable Blob in Vercel dashboard:
#   Storage → Create Database → Blob → Connect to project
# Without this, file uploads from the dashboard will fail.
BLOB_READ_WRITE_TOKEN=

# Optional: email recipient for weekly reports (used by GitHub Action)
REPORT_EMAIL_TO=
RESEND_API_KEY=
